#include <Servo.h>

Servo lidServo;
Servo flapServo;

const int trigHand = 2;
const int echoHand = 3;

const int trigWet = 4;
const int echoWet = 5;

const int trigDry = 6;
const int echoDry = 7;

const int buzzer = 8;

const int lidPin = 9;
const int flapPin = 10;

const int greenLED = 11;
const int redLED = 12;

const int moisturePin = A0;

long duration;

long getDistance(int trig, int echo)
{
  digitalWrite(trig, LOW);
  delayMicroseconds(2);

  digitalWrite(trig, HIGH);
  delayMicroseconds(10);

  digitalWrite(trig, LOW);

  duration = pulseIn(echo, HIGH);

  long distance = duration * 0.034 / 2;

  return distance;
}

void setup()
{
  pinMode(trigHand, OUTPUT);
  pinMode(echoHand, INPUT);

  pinMode(trigWet, OUTPUT);
  pinMode(echoWet, INPUT);

  pinMode(trigDry, OUTPUT);
  pinMode(echoDry, INPUT);

  pinMode(buzzer, OUTPUT);

  pinMode(redLED, OUTPUT);
  pinMode(greenLED, OUTPUT);

  lidServo.attach(lidPin);
  flapServo.attach(flapPin);

  lidServo.write(0);
  flapServo.write(90);

  Serial.begin(9600);
}
void loop()
{
  long handDistance = getDistance(trigHand, echoHand);
  long wetDistance = getDistance(trigWet, echoWet);
  long dryDistance = getDistance(trigDry, echoDry);

  int moistureValue = analogRead(moisturePin);

  Serial.print("Hand: ");
  Serial.print(handDistance);
  Serial.print(" cm  ");

  Serial.print("Wet: ");
  Serial.print(wetDistance);
  Serial.print(" cm  ");

  Serial.print("Dry: ");
  Serial.print(dryDistance);
  Serial.print(" cm  ");

  Serial.print("Moisture: ");
  Serial.println(moistureValue);

  // Hand detected
  if(handDistance > 0 && handDistance < 15)
  {
    lidServo.write(90);      // Open lid
    delay(1000);

    // Wet or Dry detection
    if(moistureValue > 550)
    {
      Serial.println("Wet Waste");

      flapServo.write(30);   // Wet bin
      delay(2000);
    }
    else
    {
      Serial.println("Dry Waste");

      flapServo.write(150);  // Dry bin
      delay(2000);
    }

    // Return flap
    flapServo.write(90);
    delay(500);

    // Close lid
    lidServo.write(0);
    delay(500);
  }
    // --------- Wet Bin Full ---------
  if (wetDistance <= 5)
  {
    digitalWrite(redLED, HIGH);
    digitalWrite(greenLED, LOW);

    tone(buzzer, 1000);
    Serial.println("WET BIN FULL");

    delay(1000);
    noTone(buzzer);
  }

  // --------- Dry Bin Full ---------
  else if (dryDistance <= 5)
  {
    digitalWrite(redLED, HIGH);
    digitalWrite(greenLED, LOW);

    tone(buzzer, 1000);
    Serial.println("DRY BIN FULL");

    delay(1000);
    noTone(buzzer);
  }

  // --------- Bin Available ---------
  else
  {
    digitalWrite(redLED, LOW);
    digitalWrite(greenLED, HIGH);

    noTone(buzzer);
  }

  delay(200);
}
